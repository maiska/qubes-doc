#, python-format
msgid ""
"configure the YubiKey for the `Challenge-Response "
"<https://en.wikipedia.org/wiki/Challenge%E2%80%93response_authentication>`__"
" mode or the NitroKey3 for `HOTP <https://en.wikipedia.org/wiki/HMAC-"
"based_one-time_password>`__ mode,"
msgstr ""

#: ../../user/security-in-qubes/mfa.rst:155 4593ad2aeb4845e7908f4ffb6cd08107
msgid ""
"store the password for YubiKey / NitroKey3 Login and the Challenge-"
"Response / HOTP secret in dom0,"
msgstr ""

#: ../../user/security-in-qubes/mfa.rst:157 1a73e17a0443482aab9265473de8621e
msgid ""
"enable YubiKey / NitroKey3 authentication for every service you want to "
"use it for."
msgstr ""

