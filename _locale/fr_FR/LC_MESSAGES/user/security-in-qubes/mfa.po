msgid "Usage"
msgstr ""

#: ../../user/security-in-qubes/mfa.rst:318 83f8baa9e397403692374a017ea2129e
msgid "When you want to authenticate"
msgstr ""

#: ../../user/security-in-qubes/mfa.rst:320 d46604ba12f8423cb7abb5e463894899
