#: fe3eca4aaf7743e4a4169206f0a4c862
msgid "Writing command-line examples"
msgstr ""

#: ../../developer/general/website-style-guide.rst:229
#: fade219192844a64bca9c9880e7e3618
msgid "When providing command-line examples:"
msgstr ""

#: ../../developer/general/website-style-guide.rst:231
#: 2fc101ed2b5b43348af39b24351aacbd
msgid ""
"Tell the reader where to open a terminal (dom0 or a specific domU), and "
"show the command along with its output (if any) in a code block, e.g.:"
msgstr ""

#: ../../developer/general/website-style-guide.rst:242
#: 8eabd3632a3741ab923d35c1548b13b3
msgid ""
"Precede each command with the appropriate command prompt: At a minimum, "
"the prompt should contain a trailing ``#`` (for the user ``root``) or "
"``$`` (for other users) on Linux systems and ``>`` on Windows systems, "
"respectively."
msgstr ""

#: ../../developer/general/website-style-guide.rst:243
#: ec8deebd06264feebf8856590b9311fc
msgid ""
"Don’t try to add comments inside the code block. For example, *don’t* do "
"this:"
msgstr ""

