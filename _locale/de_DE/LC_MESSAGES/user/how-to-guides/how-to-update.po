msgstr ""

#: ../../user/how-to-guides/how-to-update.rst:94
#: d2b5610a3c554890aa03dbea5d3ee86f
msgid ""
":ref:`update.qubes-vm <user/advanced-topics/salt:\\`\\`update.qubes-"
