msgstr ""

#: ../../user/how-to-guides/how-to-update.rst:198
#: fae74c270166410aaf4b9fa75d6eb1bc
msgid "Repeat the update process for any additional devices on your computer."
msgstr ""

#: ../../user/how-to-guides/how-to-update.rst:201
#: b9df0cd06036438a8958bf0dcedd369a
msgid "In other qubes"
msgstr ""

#: ../../user/how-to-guides/how-to-update.rst:204
