#: 2f9a17c5801a454a8f1da344baa760ac
msgid ""
"Uninstall QWT 4.1.69-1, using the standard procedure from the system "
"control panel of Windows. This will most likely result in a crash with "
"the error INACCESSIBLE BOOT DEVICE, especially if the PV drivers were "
"installed with QWT."
msgstr ""

#: ../../user/templates/windows/qubes-windows-tools.rst:641
#: d900f01928b24690a99d2cfb7e79b0e6
