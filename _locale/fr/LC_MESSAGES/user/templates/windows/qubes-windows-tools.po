msgid ""
"Start the command prompt as Administrator, i.e., right-click on the "
"Command Prompt icon (All Programs -> Accessories) and choose \"Run as "
"administrator\"."
msgstr ""

#: ../../user/templates/windows/qubes-windows-tools.rst:128
#: b5c7d9edd33848338c0240e31f11c82e
msgid "In the command prompt, type ``bcdedit /set testsigning on``"
