msgid "New features and improvements since Qubes 4.0"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:10
#: dff74ca4ed624a089f880c02e7eb313b
msgid ""
"Optional qubes-remote-support package now available from repositories "
"(strictly opt-in, no package installed by default; no new ports or "
"network connections open by default; requires explicit connection "
"initiation by the user, then requires sharing a code word with the remote"
" party before a connection can be established; see `#6364 "
"<https://github.com/QubesOS/qubes-issues/issues/6364>`__ for more "
"information)"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:12
#: 85213384fc744cc48fc2d79ac678350b
msgid ""
"Qubes firewall reworked to be more defensive (see `#5540 "
"<https://github.com/QubesOS/qubes-issues/issues/5540>`__ for details)"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:14
#: 6ba4ea8f857e46fabef214c12f4f57fb
msgid "Xen upgraded to version 4.14"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:16
#: 2ab9241a9c454faebe047b8c24d06f2c
msgid "Dom0 operating system upgraded to Fedora 32"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:18
#: 78cbc2cbc8c94a19b0b193c8b03f33e3
msgid "Default desktop environment upgraded to Xfce 4.14"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:20
#: 5f16a959cff44e92ac54318d4111c188
msgid "Upgraded default template releases"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:22
#: a66d672a35c34f439ce4955a5b4b71f3
msgid ""
"Experimental support for GUI running outside of dom0 (hybrid mode GUI "
"domain without real GPU passthrough; see `#5662 "
"<https://github.com/QubesOS/qubes-issues/issues/5662>`__ for details)"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:24
#: d2271270415147789500b793e37d2b20
msgid ""
"Experimental support for audio server running outside of dom0 (“Audio "
"domain”)"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:26
#: 4fa4424f56f341e18c0a8a64cfba1ea1
msgid "sys-firewall and sys-usb are now disposables by default"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:28
#: 400b96863d40435c8fa628607de7ded2
msgid ""
"UEFI boot now loads GRUB, which in turn loads Xen, making the boot path "
"similar to legacy boot and allowing the user to modify boot parameters or"
" choose an alternate boot menu entry"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:30
#: a084b6061c86416a8eca0106e49dfed8
msgid ""
"New qrexec policy format (see `#4370 <https://github.com/QubesOS/qubes-"
"issues/issues/4370>`__ for details)"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:32
#: 12508dae62584e4dbca3d415c832d736
msgid ""
"qrexec protocol improvements (see `#4909 <https://github.com/QubesOS"
"/qubes-issues/issues/4909>`__ for details)"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:34
#: 1a574672f05049a09512a86f4e8a869f
msgid "New qrexec-policy daemon"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:36
#: f661cbd849f349b1bf1000c793d6e06d
msgid "Simplified using in-qube kernels"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:38
#: b4c75deceb8741b8b2472a376e4f09dd
msgid ""
"Windows USB and audio support courtesy of `tabit-pro <https://github.com"
"/tabit-pro>`__ (see `#5802 <https://github.com/QubesOS/qubes-"
"issues/issues/5802>`__ and `#2624 <https://github.com/QubesOS/qubes-"
"issues/issues/2624>`__)"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:40
#: aae6aca072564ccc9cfbbf589e83f8a2
msgid "Clarified disposable-related terminology and properties"
msgstr ""

