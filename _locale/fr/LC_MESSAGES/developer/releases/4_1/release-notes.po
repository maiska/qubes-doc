"Certain files and applications are now opened in disposables, e.g., "
"Thunderbird email attachments"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:56
#: a01cc546e8bc4d1db329014c0710eed8
msgid "New graphical interface for managing testing repository updates"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:58
#: 28d883e2325b4180a25c0b136f933652
