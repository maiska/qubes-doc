#: a82e26e6c90d4e1383e2798afc2b6f2d
msgid "Default kernelopts can now be specified by a kernel package"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:44
#: 2df59ba6f7a54fe5bd368cf748f49f0d
msgid "Improved support for high-resolution displays"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:46
#: 94b4375df76e4383a799c1dc71a2398d
msgid "Improved notifications when a system drive runs out of free space"
