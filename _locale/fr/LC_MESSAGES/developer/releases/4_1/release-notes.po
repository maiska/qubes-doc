msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:60
#: 261318c1b45044ccbd1eddce513d7484
msgid "Disposable qube types now use the disposable icon"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:62
#: 1371fe9a35dc426bb91d91f186d060d1
msgid ""
"New Template Manager tool for installing, removing, and updating "
"templates (meanwhile, the tool previously known as the “Template "
"Manager,” which was for mass template switching, has been integrated into"
" the Qube Manager)"
msgstr ""

#: ../../developer/releases/4_1/release-notes.rst:64
#: 240b39210d464a338743e9efe4657e62
msgid ""
"The “file” storage driver has been deprecated in Qubes 4.1 and will be "
"removed in Qubes 4.2"
msgstr ""

